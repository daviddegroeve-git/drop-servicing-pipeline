{
    "version": 2,
    "functions": {
        "api/**/*.js": {
            "maxDuration": 120
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/site/(.*)",
            "destination": "/api/preview?id=$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}